---
// Category index: /blog/category/<category>/
// Lists every article whose frontmatter `category` matches.

import { getCollection } from "astro:content";
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import "../../styles/blog.css";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const __dir = dirname(fileURLToPath(import.meta.url));
const publicImg = resolve(__dir, "../../../public/img");
const hasHero = (slug: string) =>
  existsSync(`${publicImg}/${slug}-hero.png`);

export async function getStaticPaths() {
  const all = await getCollection("blog", ({ data }) => data.draft !== true);
  const cats = [...new Set(all.map((p) => p.data.category))];
  return cats.map((cat) => ({
    params: { category: cat },
    props: { category: cat, posts: all.filter((p) => p.data.category === cat) },
  }));
}

const { category, posts } = Astro.props as { category: string; posts: any[] };
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const url = `https://cbtcbook.com/blog/category/${category}/`;
const niceCat = category.charAt(0).toUpperCase() + category.slice(1);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{niceCat} articles — cbtcbook.com</title>
  <meta name="description" content={`Articles in the ${niceCat} category on cbtcbook.com.`} />
  <link rel="canonical" href={url} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:wght@400;500;600&display=swap" />
</head>
<body>
  <SiteNav active="articles" />
  <main class="blog-index">
    <p class="blog-kicker" style="margin-bottom:18px;">Category</p>
    <h1>{niceCat}</h1>
    <p class="lede">
      {posts.length} {posts.length === 1 ? "article" : "articles"} on
      {category}. Most recent first.
      <a href="/blog/" style="display:inline-block;margin-left:14px;font-family:var(--mono);font-size:12px;letter-spacing:1.4px;text-transform:uppercase;color:var(--amber);">← All articles</a>
    </p>
    <div class="blog-cards">
      {posts.map((p) => (
        <a class="blog-card" href={`/blog/${p.slug}/`}>
          {hasHero(p.slug) && (
            <img class="blog-card__hero" src={`/blog/img/${p.slug}-hero.png`}
                 alt="" loading="lazy" />
          )}
          <div class="blog-card__body">
            <span class="blog-card__cat">{p.data.category}</span>
            <h2 class="blog-card__title">{p.data.title}</h2>
            <p class="blog-card__desc">{p.data.description}</p>
            <div class="blog-card__meta">
              <span>{p.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
              {p.data.read_time && <span>{p.data.read_time}</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
  <SiteFooter />
</body>
</html>
