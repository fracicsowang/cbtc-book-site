---
// Email subscription capture.
//
// MVP behavior: posts {email, source_slug} to a Formspree endpoint.
// You'll need to:
//   1. Sign up at https://formspree.io (free tier = 50 submissions/month)
//   2. Create a form, get its endpoint URL (e.g. https://formspree.io/f/xxxxx)
//   3. Replace `FORM_ENDPOINT` below with your real endpoint
//
// Why Formspree: zero backend, GDPR-OK, plays well with static GitHub Pages.
// Alternative: ConvertKit / Beehiiv / Mailchimp (more features, more setup).
//
// On submit: shows inline success state, no full-page reload.

const FORM_ENDPOINT =
  import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || "https://formspree.io/f/REPLACE_ME";

interface Props {
  slug?: string;
}
const { slug = "" } = Astro.props;
---
<aside class="blog-newsletter">
  <h3>Join the cbtcbook.com mailing list</h3>
  <p>
    A short email each time a new article ships — currently about one a day.
    No spam, unsubscribe anytime.
  </p>
  <form action={FORM_ENDPOINT} method="POST" data-newsletter>
    <input type="email" name="email" placeholder="you@example.com" required autocomplete="email" />
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
    <input type="hidden" name="source_slug" value={slug} />
    <input type="hidden" name="_subject" value="New cbtcbook.com newsletter signup" />
    <button type="submit">Subscribe</button>
  </form>
  <p class="blog-newsletter__status" data-newsletter-status role="status" aria-live="polite" hidden></p>
  <p class="blog-newsletter__note">No tracking pixels. One-click unsubscribe in every email.</p>
</aside>

<script>
  document.querySelectorAll<HTMLFormElement>("form[data-newsletter]").forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLParagraphElement>("[data-newsletter-status]");
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    const original = btn.textContent || "Subscribe";

    const showStatus = (msg: string, kind: "success" | "error") => {
      if (!status) return;
      status.textContent = msg;
      status.className = `blog-newsletter__status is-${kind}`;
      status.hidden = false;
    };

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      if (status) status.hidden = true;
      btn.disabled = true;
      btn.textContent = "Subscribing…";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (!res.ok) throw new Error("submit failed");
        form.hidden = true;
        showStatus("✓ Thanks — you're on the cbtcbook.com mailing list.", "success");
      } catch {
        btn.disabled = false;
        btn.textContent = original;
        showStatus("Something went wrong — please check your email address and try again.", "error");
      }
    });
  });
</script>
