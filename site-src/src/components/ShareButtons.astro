---
// One-click share row — LinkedIn, X/Twitter, Email, Copy-link.
// Pure HTML/CSS + a small inline script for clipboard. No external trackers.
//
// Props:
//   url   — full canonical URL of this article
//   title — article title (for share text)

interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;

const enc = (s: string) => encodeURIComponent(s);
const linkedin = `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`;
const twitter = `https://twitter.com/intent/tweet?text=${enc(title)}&url=${enc(url)}`;
const email = `mailto:?subject=${enc(title)}&body=${enc(url)}`;
---
<div class="blog-share" aria-label="Share this article">
  <span>Share:</span>
  <a class="blog-share__btn" href={linkedin} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"/></svg>
    LinkedIn
  </a>
  <a class="blog-share__btn" href={twitter} target="_blank" rel="noopener" aria-label="Share on X">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2H21.5l-7.4 8.46L23 22h-6.844l-5.36-7.01L4.7 22H1.43l7.92-9.05L1 2h7.02l4.84 6.4L18.244 2zm-1.196 18h1.81L7.05 4H5.07l11.978 16z"/></svg>
    X
  </a>
  <a class="blog-share__btn" href={email} aria-label="Share by email">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 4h20a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm10 9.06l9.57-6.06H2.43L12 13.06zM2 8.34V18h20V8.34l-10 6.33L2 8.34z"/></svg>
    Email
  </a>
  <button type="button" class="blog-share__btn" data-copy={url} aria-label="Copy article link">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H8V7h11v14z"/></svg>
    Copy link
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>("button.blog-share__btn[data-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-copy") || "";
      try {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = "Copied ✓";
        setTimeout(() => { btn.innerHTML = original || ""; }, 1500);
      } catch {
        // older browser fallback
        prompt("Copy link:", url);
      }
    });
  });
</script>
