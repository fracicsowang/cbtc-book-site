---
// BlogPostLayout — single article page.
// Contains: <head> with full SEO metadata + JSON-LD Article schema,
// SiteNav, article body, share row, newsletter signup, CTA block, footer.

import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import "../styles/blog.css";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ShareButtons from "../components/ShareButtons.astro";
import Newsletter from "../components/Newsletter.astro";
import CTABlock from "../components/CTABlock.astro";

const __dir = dirname(fileURLToPath(import.meta.url));
const publicImg = resolve(__dir, "../../public/img");

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    author?: string;
    category: string;
    tags: string[];
    primary_keyword: string;
    secondary_keywords?: string[];
    related_chapters?: number[];
    og_image?: string;
    read_time?: string;
  };
  slug?: string;
}

const { frontmatter, slug = "" } = Astro.props;
const author = frontmatter.author ?? "Chunjun (Francisco) Wang";
const dateISO = frontmatter.date.toISOString();
const dateNice = frontmatter.date.toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric",
});
const url = new URL(Astro.url.pathname, "https://cbtcbook.com").toString();

// Prefer the per-article hero card if it exists; fall back to the
// site-level OG image. The frontmatter `og_image` field is ignored
// (those URLs were drafted before hero generation existed and 404).
const heroExists = !!slug && existsSync(`${publicImg}/${slug}-hero.png`);
const heroPath = heroExists ? `/blog/img/${slug}-hero.png` : null;
const ogImage = heroPath
  ? new URL(heroPath, "https://cbtcbook.com").toString()
  : "https://cbtcbook.com/assets/og-image.png";

// JSON-LD Article schema for rich-result eligibility.
const jsonLD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: dateISO,
  dateModified: dateISO,
  author: {
    "@type": "Person",
    name: author,
    url: "https://cbtcbook.com/about.html",
  },
  publisher: {
    "@type": "Organization",
    name: "cbtcbook.com",
    logo: { "@type": "ImageObject", url: "https://cbtcbook.com/icon-512.png" },
  },
  image: ogImage,
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  keywords: [frontmatter.primary_keyword, ...(frontmatter.secondary_keywords ?? [])].join(", "),
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{frontmatter.title} — cbtcbook.com</title>
  <meta name="description" content={frontmatter.description} />
  <link rel="canonical" href={url} />

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={frontmatter.title} />
  <meta property="og:description" content={frontmatter.description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="cbtcbook.com" />
  <meta property="article:published_time" content={dateISO} />
  <meta property="article:author" content={author} />
  <meta property="article:section" content={frontmatter.category} />
  {frontmatter.tags.map((t) => <meta property="article:tag" content={t} />)}

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={frontmatter.title} />
  <meta name="twitter:description" content={frontmatter.description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon set (already deployed at site root) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:wght@400;500;600&display=swap" />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-0NF9Z0T953"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", "G-0NF9Z0T953", { send_page_view: true });
  </script>
</head>
<body>
  <SiteNav active="articles" />

  <main class="blog-shell">
    <article class="blog-article">
      <p class="blog-kicker">{frontmatter.category} · Article</p>
      <h1 class="blog-title">{frontmatter.title}</h1>
      <p class="blog-meta">
        <span>{dateNice}</span>
        {frontmatter.read_time && <span>{frontmatter.read_time}</span>}
        <span>{author}</span>
      </p>

      {heroPath && (
        <img class="blog-hero" src={heroPath} alt="" />
      )}

      <div class="blog-prose">
        <slot />
      </div>

      <ShareButtons url={url} title={frontmatter.title} />
      <CTABlock related_chapters={frontmatter.related_chapters ?? []} />
      <Newsletter slug={slug} />
    </article>
  </main>

  <SiteFooter />

  <!-- Read-complete event: fires when reader scrolls to the end of the article -->
  <script>
    const cta = document.querySelector(".blog-cta");
    if (cta && "IntersectionObserver" in window) {
      const obs = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            const w = window as any;
            if (typeof w.gtag === "function") {
              w.gtag("event", "blog_read_complete", { page_path: location.pathname });
            }
            obs.disconnect();
          }
        }
      }, { threshold: 0.5 });
      obs.observe(cta);
    }
  </script>
</body>
</html>
